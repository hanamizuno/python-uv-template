# Sample pass:// references — copy to .env (kept git-ignored) and adjust.
#
# Values are *references* into the Proton Pass "agent-secrets" vault, not secrets:
# `pass-cli run --env-file .env -- <cmd>` resolves them at run time and injects the
# real values only into <cmd>'s environment (masked in stdout/stderr).
# Note: item names are metadata — committing this file exposes them, not the values.

# GitHub fine-grained PAT (gh CLI / git push)
GITHUB_TOKEN=pass://agent-secrets/github-fine-grained/token
GH_TOKEN=pass://agent-secrets/github-fine-grained/token

# Generic API keys
# OPENAI_API_KEY=pass://agent-secrets/openai/api-key
# CLOUDFLARE_API_TOKEN=pass://agent-secrets/cloudflare/api-token
