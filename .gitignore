# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Tool caches
# (ruff and uv also drop their own .gitignore inside these, but be explicit)
.ruff_cache/
.uv-cache/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Virtual environments
.venv

# macOS
.DS_Store

# Host config staged for the devcontainer (see .devcontainer/initialize.sh)
.devcontainer/host-gitignore
.devcontainer/host-gituser
.devcontainer/host-claude/
