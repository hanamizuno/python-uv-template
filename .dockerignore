__pycache__/
*.py[oc]
.pytest_cache/
.ruff_cache/
.uv-cache/

# Test / coverage artifacts
htmlcov/
.coverage
.coverage.*

# Local editor/agent state and host config staged for the devcontainer
.claude/
.devcontainer/
.vscode/
